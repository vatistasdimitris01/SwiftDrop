rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: shares
    // Document ID: auto-generated
    // Fields:
    //   - content: string (required) - The text or base64 data
    //   - contentType: string (required) - text, image, video, file
    //   - fileName: string (optional) - Original filename
    //   - createdAt: timestamp (required) - Creation time
    //   - expiresAt: timestamp (required) - Expiration time (30 days)
    //   - authorId: string (optional) - Creator UID
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isNotExpired() {
      return request.time < resource.data.expiresAt;
    }

    function isValidShare(data) {
      return data.keys().hasAll(['content', 'contentType', 'createdAt', 'expiresAt']) &&
             data.content is string &&
             data.content.size() < 1048576 && // 1MB limit for Firestore docs
             data.contentType in ['text', 'image', 'video', 'file'] &&
             data.createdAt is timestamp &&
             data.expiresAt is timestamp &&
             data.expiresAt == data.createdAt + duration.value(30, 'd');
    }

    match /shares/{shareId} {
      // Anyone can read if not expired
      allow read: if isNotExpired();
      
      // Anyone can create (anonymous or logged in)
      allow create: if isValidShare(request.resource.data);
      
      // No updates or deletes for now to keep it simple and secure
      allow update, delete: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
